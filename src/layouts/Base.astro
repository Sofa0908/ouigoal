---
import '../styles/global.css';
import { dict, localeUrl, SITE, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  /** Logical path without base or locale prefix, e.g. "/" or "/services/explore-study" */
  path: string;
  title?: string;
  description?: string;
}

const { locale, path, title, description } = Astro.props;
const t = dict[locale];
const otherLocale: Locale = locale === 'zh' ? 'en' : 'zh';
const url = (p: string) => localeUrl(locale, p);
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

const servicePages = [t.pages.explore, t.pages.work, t.pages.partner];
const pageTitle = title ? `${title} — ${SITE.brand}` : t.meta.title;
const pageDescription = description ?? t.meta.description;
const year = new Date().getFullYear();
---

<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Inter:wght@400;500;600&family=Noto+Serif+TC:wght@500;600;700&family=Noto+Sans+TC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-navy-900 antialiased">
    <header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-navy-900/95 backdrop-blur">
      <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 lg:px-8">
        <a href={url('/')} class="flex items-center gap-2.5">
          <svg viewBox="0 0 64 64" class="h-8 w-8" aria-hidden="true">
            <rect width="64" height="64" rx="14" fill="#0c1d38"></rect>
            <circle cx="32" cy="32" r="17" fill="none" stroke="#e8a33d" stroke-width="3"></circle>
            <ellipse cx="32" cy="32" rx="8" ry="17" fill="none" stroke="#e8a33d" stroke-width="2"></ellipse>
            <line x1="15" y1="32" x2="49" y2="32" stroke="#e8a33d" stroke-width="2"></line>
          </svg>
          <span class="font-display text-lg font-semibold tracking-wide text-white">OuiGoal</span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden items-center gap-8 md:flex">
          <a href={url('/')} class="text-sm font-medium text-white/80 transition hover:text-gold-400">{t.nav.home}</a>
          <a href={`${url('/')}#about`} class="text-sm font-medium text-white/80 transition hover:text-gold-400">{t.nav.about}</a>
          <div class="group relative">
            <button
              class="flex items-center gap-1 text-sm font-medium text-white/80 transition group-hover:text-gold-400"
              aria-haspopup="true"
            >
              {t.nav.services}
              <svg class="h-3.5 w-3.5 transition group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="invisible absolute left-1/2 top-full -translate-x-1/2 pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
              <div class="w-72 overflow-hidden rounded-xl border border-navy-100 bg-white shadow-xl shadow-navy-900/10">
                {servicePages.map((p) => (
                  <a
                    href={url(`/services/${p.slug}`)}
                    class="block border-b border-navy-50 px-5 py-3.5 transition last:border-0 hover:bg-navy-50"
                  >
                    <span class="block text-sm font-semibold text-navy-900">{p.name}</span>
                    <span class="block text-xs text-navy-400">{p.subtitle}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
          <a href={`${url('/')}#contact`} class="text-sm font-medium text-white/80 transition hover:text-gold-400">{t.nav.contact}</a>
          <a
            href={localeUrl(otherLocale, path)}
            class="rounded-full border border-white/25 px-3.5 py-1.5 text-xs font-semibold tracking-wide text-white/90 transition hover:border-gold-400 hover:text-gold-400"
          >
            {locale === 'zh' ? 'EN' : '中文'}
          </a>
        </div>

        <!-- Mobile controls -->
        <div class="flex items-center gap-3 md:hidden">
          <a
            href={localeUrl(otherLocale, path)}
            class="rounded-full border border-white/25 px-3 py-1 text-xs font-semibold text-white/90"
          >
            {locale === 'zh' ? 'EN' : '中文'}
          </a>
          <button id="menu-toggle" class="p-1 text-white" aria-label="Menu" aria-expanded="false">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
            </svg>
          </button>
        </div>
      </nav>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden border-t border-white/10 bg-navy-900 px-5 pb-5 pt-2 md:hidden">
        <a href={url('/')} class="block py-2.5 text-sm font-medium text-white/85">{t.nav.home}</a>
        <a href={`${url('/')}#about`} class="block py-2.5 text-sm font-medium text-white/85">{t.nav.about}</a>
        <p class="pb-1 pt-2.5 text-xs font-semibold uppercase tracking-widest text-white/40">{t.nav.services}</p>
        {servicePages.map((p) => (
          <a href={url(`/services/${p.slug}`)} class="block py-2 pl-3 text-sm text-white/85">
            {p.name} <span class="text-white/40">· {p.subtitle}</span>
          </a>
        ))}
        <a href={`${url('/')}#contact`} class="block py-2.5 text-sm font-medium text-white/85">{t.nav.contact}</a>
      </div>
    </header>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="bg-navy-950 py-10 text-center">
      <p class="font-display text-sm font-semibold tracking-wide text-white/90">{SITE.companyEn}</p>
      <p class="mt-1 text-sm text-white/60">{SITE.companyZh}</p>
      <p class="mt-4 text-xs text-white/35">© {year} {SITE.brand}. {t.footer.rights}</p>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => {
        const open = menu?.classList.toggle('hidden') === false;
        toggle.setAttribute('aria-expanded', String(open));
      });
    </script>
  </body>
</html>
