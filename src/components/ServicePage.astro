---
import Base from '../layouts/Base.astro';
import { dict, localeUrl, type Locale, type ServicePage } from '../i18n/ui';

interface Props {
  locale: Locale;
  page: ServicePage;
}

const { locale, page } = Astro.props;
const t = dict[locale];
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const image = `${base}/images/${page.slug}.jpg`;
---

<Base locale={locale} path={`/services/${page.slug}`} title={page.name} description={page.intro}>
  <!-- ── Page hero ────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-navy-900 py-24">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-700"></div>
    <svg
      class="pointer-events-none absolute inset-0 h-full w-full opacity-30"
      viewBox="0 0 1440 400"
      fill="none"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
    >
      <circle cx="1220" cy="60" r="240" stroke="#3d6190" stroke-width="1" opacity="0.5"></circle>
      <circle cx="1220" cy="60" r="340" stroke="#3d6190" stroke-width="1" opacity="0.3"></circle>
      <path d="M120 340 Q 620 120 1200 200" stroke="#e8a33d" stroke-width="1.5" stroke-dasharray="2 8" opacity="0.9"></path>
      <circle cx="120" cy="340" r="4" fill="#e8a33d"></circle>
      <circle cx="1200" cy="200" r="6" fill="#e8a33d"></circle>
    </svg>
    <div class="relative mx-auto max-w-6xl px-5 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-gold-400">{page.subtitle}</p>
      <h1 class="mt-3 font-display text-4xl font-semibold text-white sm:text-5xl">{page.name}</h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-navy-100">{page.tagline}</p>
    </div>
  </section>

  <!-- ── Intro + services ─────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-6xl px-5 lg:px-8">
      <div class="grid items-center gap-10 md:grid-cols-2">
        <p class="text-base leading-loose text-navy-600">{page.intro}</p>
        <img
          src={image}
          alt={page.name}
          loading="lazy"
          class="aspect-[4/3] w-full rounded-2xl object-cover shadow-lg shadow-navy-900/10"
        />
      </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-2">
        {page.items.map((item, i) => (
          <div class="group rounded-2xl border border-navy-100 bg-white p-8 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-navy-200 hover:shadow-lg">
            <span class="font-display text-3xl font-semibold text-gold-500/80">{String(i + 1).padStart(2, '0')}</span>
            <h2 class="mt-4 font-display text-xl font-semibold text-navy-900">{item.title}</h2>
            <div class="mt-3 h-px w-10 bg-gold-500 transition-all duration-300 group-hover:w-16"></div>
            <p class="mt-4 text-sm leading-relaxed text-navy-500">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA band ─────────────────────────────────────── -->
  <section class="bg-navy-900 py-16">
    <div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-5 text-center lg:px-8">
      <p class="font-display text-2xl font-semibold text-white">{t.contact.heading}</p>
      <a
        href={`${localeUrl(locale, '/')}#contact`}
        class="inline-block rounded-full bg-gold-500 px-8 py-3.5 text-sm font-bold tracking-wide text-navy-950 shadow-lg shadow-gold-500/25 transition hover:-translate-y-0.5 hover:bg-gold-400"
      >
        {t.hero.cta}
      </a>
    </div>
  </section>
</Base>
